#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
set -euo pipefail

# --- Testable seams ---
OPENROUTER_CHECK_URL="${OPENROUTER_CHECK_URL:-https://openrouter.ai/api/v1/models}"
# larql serve requires larql-server built alongside the main binary.
# Build with: cargo build --release -p larql-server (then both land in the same target/release/).
# Until larql-server ships in the release build, set LARQL_BIN to your debug build path.
LARQL_BIN="${LARQL_BIN:-$HOME/larql/target/release/larql}"
LARQL_PORT="${LARQL_PORT:-8080}"
LARQL_VINDEX="${LARQL_VINDEX:-smollm2-360m}"
OPENROUTER_MODEL="${OPENROUTER_MODEL:-qwen/qwen3-coder:free}"
GOOSE_BIN="${GOOSE_BIN:-goose}"
# larql-server pre-loads weights: ~16s for smollm2-360m (vs 40min for 7B via Ollama)
LARQL_START_TIMEOUT="${LARQL_START_TIMEOUT:-30}"
LARQL_LOG_FILE="${LARQL_LOG_FILE:-/tmp/larql-server-${LARQL_PORT}.log}"
# timeout for a single Goose inference call; 124 = timeout exit code
LARQL_INFERENCE_TIMEOUT="${LARQL_INFERENCE_TIMEOUT:-120}"

usage() {
  cat <<'EOF'
Usage: coding-agent [OPTIONS] "TASK"

Options:
  --model M     Force provider/model (e.g. openrouter/qwen/qwen3-235b-a22b:free
                or larql/smollm2-360m)
  -h, --help    Show this help

Note: quote the TASK string to preserve spaces: coding-agent "write a hello function"
EOF
}

_check_openrouter() {
  curl -sf --max-time 3 "$OPENROUTER_CHECK_URL" > /dev/null 2>&1
}

_check_larql() {
  curl -sf --max-time 3 "http://localhost:${LARQL_PORT}/v1/models" > /dev/null 2>&1
}

_start_larql_server() {
  local vindex="$1"
  echo "coding-agent: starting larql serve $vindex on port $LARQL_PORT..." >&2
  echo "coding-agent: larql-server log: $LARQL_LOG_FILE" >&2
  "$LARQL_BIN" serve "$vindex" --port "$LARQL_PORT" >> "$LARQL_LOG_FILE" 2>&1 &
  local server_pid=$!
  # larql-server pre-loads weights on startup; poll up to LARQL_START_TIMEOUT seconds
  local deadline=$(( $(date +%s) + LARQL_START_TIMEOUT ))
  trap "kill $server_pid 2>/dev/null || true" EXIT
  while [ "$(date +%s)" -lt "$deadline" ]; do
    if _check_larql; then
      echo "coding-agent: larql serve ready (PID $server_pid)" >&2
      trap - EXIT
      return 0
    fi
    sleep 0.2
  done
  echo "coding-agent: timeout waiting for larql serve to start" >&2
  return 1
}

_run_goose_openrouter() {
  local model="$1" task="$2"
  echo "coding-agent: provider=openrouter model=$model" >&2
  GOOSE_PROVIDER=openrouter GOOSE_MODEL="$model" GOOSE_MODE=auto \
    "$GOOSE_BIN" run -t "$task"
}

_run_goose_larql() {
  local vindex="$1" task="$2"
  echo "coding-agent: provider=larql (openai-compat) model=$vindex" >&2
  GOOSE_PROVIDER=openai \
    OPENAI_BASE_URL="http://localhost:${LARQL_PORT}/v1" \
    OPENAI_API_KEY=larql \
    GOOSE_MODEL="$vindex" \
    GOOSE_MODE=auto \
    timeout "$LARQL_INFERENCE_TIMEOUT" \
    "$GOOSE_BIN" run -t "$task"
}

# --- Argument parsing ---
MODEL_OVERRIDE=""
TASK=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --model) MODEL_OVERRIDE="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    -*) echo "coding-agent: unknown option: $1" >&2; usage; exit 1 ;;
    # Accumulate positional args so unquoted "write hello function" works as one task
    *) TASK="${TASK:+$TASK }$1"; shift ;;
  esac
done

if [ -z "$TASK" ]; then
  echo "coding-agent: TASK argument required" >&2
  usage
  exit 1
fi

# --- Model override: larql/VINDEX forces local path regardless of OpenRouter ---
if [ -n "$MODEL_OVERRIDE" ]; then
  local_provider="${MODEL_OVERRIDE%%/*}"
  local_model="${MODEL_OVERRIDE#*/}"
  if [ "$local_provider" = "larql" ]; then
    if ! _check_larql; then
      _start_larql_server "$local_model" || exit 1
    fi
    _run_goose_larql "$local_model" "$TASK"
    exit $?
  else
    _run_goose_openrouter "$local_model" "$TASK"
    exit $?
  fi
fi

# --- Auto-select provider ---
if _check_openrouter; then
  _run_goose_openrouter "$OPENROUTER_MODEL" "$TASK"
else
  local_vindex="$LARQL_VINDEX"
  if ! _check_larql; then
    _start_larql_server "$local_vindex" || exit 1
  fi
  _run_goose_larql "$local_vindex" "$TASK"
fi

#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
set -euo pipefail

# --- Testable seams ---
PI_BIN="${PI_BIN:-$(command -v pi 2>/dev/null || echo "$HOME/.local/share/pi-node/current/bin/pi")}"
OPENROUTER_CHECK_URL="${OPENROUTER_CHECK_URL:-https://openrouter.ai/api/v1/models}"
OLLAMA_URL="${OLLAMA_URL:-http://localhost:11434}"
CGROUP_ROOT="${CGROUP_ROOT:-/sys/fs/cgroup}"
source "$(dirname "$0")/../lib/harness-common.sh"

# --- Defaults ---
OPENROUTER_MODEL="${OPENROUTER_MODEL:-auto}"
OLLAMA_MODEL="${OLLAMA_MODEL:-qwen2.5-coder:7b}"
CGROUP_NAME="babel-harness"
CGROUP_MEMORY_BYTES=5368709120  # 5 GB
CGROUP_CPU_RESERVE_CORES="${CGROUP_CPU_RESERVE_CORES:-2}"  # cores to leave free for OS
OLLAMA_WARMUP_POLL_INTERVAL="${OLLAMA_WARMUP_POLL_INTERVAL:-10}"  # seconds between api/ps polls
OLLAMA_WARMUP_TIMEOUT="${OLLAMA_WARMUP_TIMEOUT:-1200}"            # 20 min; CPU load is slow

usage() {
  cat <<'EOF'
Usage: pi-harness [OPTIONS] TASK

Options:
  --status        Report OpenRouter and Ollama health
  --repair        Attempt to fix Ollama (restart service)
  --model M       Override model, format: provider/model
  -h, --help      Show this help
EOF
}

_check_ollama() {
  curl -sf --max-time 3 "$OLLAMA_URL" > /dev/null 2>&1
}

_warmup_ollama_model() {
  local model="$1"
  local ps_resp

  ps_resp=$(curl -sf --max-time 5 "$OLLAMA_URL/api/ps" 2>/dev/null)
  if echo "$ps_resp" | grep -q "\"$model\""; then
    echo "pi-harness: $model already loaded" >&2
    return 0
  fi

  # Trigger model load in background — connection must stay open until Ollama finishes
  # loading; if the client disconnects first, Ollama aborts the load entirely.
  echo "pi-harness: loading $model (CPU-only; may take several minutes)..." >&2
  curl -sf "$OLLAMA_URL/api/generate" \
    -d "{\"model\":\"$model\",\"prompt\":\"\",\"stream\":false,\"options\":{\"num_predict\":0}}" \
    > /dev/null 2>&1 &
  local load_pid=$!

  # Poll until the runner appears in api/ps, then release the generate connection
  local deadline=$(( $(date +%s) + OLLAMA_WARMUP_TIMEOUT ))
  while [ "$(date +%s)" -lt "$deadline" ]; do
    ps_resp=$(curl -sf --max-time 5 "$OLLAMA_URL/api/ps" 2>/dev/null)
    if echo "$ps_resp" | grep -q "\"$model\""; then
      kill "$load_pid" 2>/dev/null || true
      echo "pi-harness: $model ready" >&2
      return 0
    fi
    sleep "$OLLAMA_WARMUP_POLL_INTERVAL"
  done

  kill "$load_pid" 2>/dev/null || true
  echo "pi-harness: timeout after ${OLLAMA_WARMUP_TIMEOUT}s waiting for $model to load" >&2
  return 1
}

_repair_ollama() {
  echo "pi-harness: restarting Ollama..." >&2
  sudo systemctl restart ollama >&2 2>&1
  sleep 2
  _check_ollama
}

_setup_cgroup() {
  local cg_mem="${CGROUP_ROOT}/memory/$CGROUP_NAME"
  local cg_cpu="${CGROUP_ROOT}/cpu/$CGROUP_NAME"
  sudo mkdir -p "$cg_mem" "$cg_cpu" 2>/dev/null || return 1

  # Memory — hard ceiling; prevents OOM on the shared heap
  echo "$CGROUP_MEMORY_BYTES" | sudo tee "$cg_mem/memory.limit_in_bytes" > /dev/null 2>&1 || return 1
  echo "0" | sudo tee "$cg_mem/memory.swappiness" > /dev/null 2>&1 || true

  # CPU quota — enforced here, not borrowed from the environment's service unit
  local ncores period quota
  ncores=$(nproc 2>/dev/null || echo 4)
  period=100000  # 100 ms scheduling window
  local allowed=$(( ncores > CGROUP_CPU_RESERVE_CORES ? ncores - CGROUP_CPU_RESERVE_CORES : 1 ))
  quota=$(( allowed * period ))
  echo "$period" | sudo tee "$cg_cpu/cpu.cfs_period_us" > /dev/null 2>&1 || true
  echo "$quota"  | sudo tee "$cg_cpu/cpu.cfs_quota_us"  > /dev/null 2>&1 || true

  return 0
}

_enroll_ollama_in_cgroup() {
  # Move the live Ollama server process into this harness's cgroup so its CPU
  # and memory are bounded by the same limits as Pi — regardless of whether
  # the systemd unit has CPUQuota or any other external constraint set.
  local ollama_pid
  ollama_pid=$(pgrep -f "ollama serve" 2>/dev/null | head -1) || return 0
  [ -z "$ollama_pid" ] && return 0
  echo "$ollama_pid" | sudo tee "${CGROUP_ROOT}/cpu/$CGROUP_NAME/cgroup.procs"    > /dev/null 2>&1 || true
  echo "$ollama_pid" | sudo tee "${CGROUP_ROOT}/memory/$CGROUP_NAME/cgroup.procs" > /dev/null 2>&1 || true
  echo "pi-harness: enrolled ollama PID $ollama_pid in $CGROUP_NAME cgroup" >&2
}

cmd_status() {
  if _check_openrouter; then
    echo "OpenRouter: reachable"
  else
    echo "OpenRouter: unreachable"
  fi
  if _check_ollama; then
    echo "Ollama:     running"
  else
    echo "Ollama:     not running"
  fi
}

cmd_repair() {
  if _repair_ollama; then
    echo "pi-harness: Ollama is now running" >&2
    return 0
  else
    echo "pi-harness: Ollama repair failed" >&2
    return 1
  fi
}

_select_provider_model() {
  if _check_openrouter; then
    echo "openrouter $OPENROUTER_MODEL"
  elif _check_ollama; then
    echo "ollama $OLLAMA_MODEL"
  elif _repair_ollama; then
    echo "ollama $OLLAMA_MODEL"
  else
    echo "none none"
  fi
}

cmd_run() {
  local task="$1"
  local model_override="${2:-}"

  local provider model
  if [ -n "$model_override" ]; then
    provider="${model_override%%/*}"
    model="${model_override#*/}"
  else
    read -r provider model < <(_select_provider_model)
    if [ "$provider" = "none" ]; then
      echo '{"error":"no provider available — OpenRouter unreachable and Ollama failed to start"}' >&2
      return 1
    fi
  fi

  echo "pi-harness: provider=$provider model=$model" >&2

  if ! _setup_cgroup; then
    echo "pi-harness: FATAL: cgroup enforcement required but setup failed" >&2
    echo "pi-harness: running unconstrained risks CPU/memory exhaustion on this hardware" >&2
    echo "pi-harness: check sudo permissions for ${CGROUP_ROOT}" >&2
    return 1
  fi

  # Enroll Ollama before warmup so the model loads within the cgroup's CPU budget
  [ "$provider" = "ollama" ] && _enroll_ollama_in_cgroup

  if [ "$provider" = "ollama" ]; then
    _warmup_ollama_model "$model" || return 1
  fi

  (
    # Capture $BASHPID before entering any pipeline: the pipeline creates a new
    # subshell for echo, so $BASHPID inside the pipeline is the echo-subshell's
    # PID — which exits before tee writes, producing silent ENOENT.
    _self=$BASHPID
    echo "$_self" | sudo tee "${CGROUP_ROOT}/cpu/$CGROUP_NAME/cgroup.procs"    > /dev/null 2>&1 || true
    echo "$_self" | sudo tee "${CGROUP_ROOT}/memory/$CGROUP_NAME/cgroup.procs" > /dev/null 2>&1 || true
    exec "$PI_BIN" --provider "$provider" --model "$model" --print --mode json "$task"
  )
}

# --- Argument parsing ---
MODEL_OVERRIDE=""
TASK=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --status)  cmd_status; exit 0 ;;
    --repair)  cmd_repair; exit $? ;;
    --model)   MODEL_OVERRIDE="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    -*)        echo "pi-harness: unknown option: $1" >&2; usage; exit 1 ;;
    *)         TASK="$1"; shift ;;
  esac
done

if [ -z "$TASK" ]; then
  echo "pi-harness: TASK argument required" >&2
  usage
  exit 1
fi

cmd_run "$TASK" "$MODEL_OVERRIDE"

#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# Testable seams:
#   MOCK_CURL_OPENROUTER_EXIT / MOCK_CURL_OLLAMA_EXIT / MOCK_CURL_EXIT — exit codes
#   MOCK_CALL_LOG — if set, each endpoint call is appended (one word per line)
#   MOCK_OLLAMA_MODEL_LOADED — "1" → api/ps returns model immediately
#   MOCK_OLLAMA_MODEL_NAME — model name for api/ps response (default: qwen2.5-coder:7b)
#   MOCK_PS_LOADED_AFTER — api/ps returns loaded only after this many calls (uses counter file)
#   MOCK_PS_COUNTER_FILE — counter state file for MOCK_PS_LOADED_AFTER
#   MOCK_LARQL_PORT_RUNNING — port number of a "running" larql-server; v1/models succeeds only for this port

args="$*"

_log() { [ -n "${MOCK_CALL_LOG:-}" ] && echo "$1" >> "$MOCK_CALL_LOG"; }

if echo "$args" | grep -q "openrouter"; then
  _log "openrouter"
  exit "${MOCK_CURL_OPENROUTER_EXIT:-${MOCK_CURL_EXIT:-0}}"

elif echo "$args" | grep -q "api/generate"; then
  _log "api/generate"
  ollama_exit="${MOCK_CURL_OLLAMA_EXIT:-${MOCK_CURL_EXIT:-0}}"
  [ "$ollama_exit" = "0" ] && echo '{"done":true}'
  exit "$ollama_exit"

elif echo "$args" | grep -q "api/ps"; then
  _log "api/ps"
  model_name="${MOCK_OLLAMA_MODEL_NAME:-qwen2.5-coder:7b}"
  loaded="${MOCK_OLLAMA_MODEL_LOADED:-0}"

  # Stateful: become loaded after N calls
  if [ -n "${MOCK_PS_LOADED_AFTER:-}" ] && [ -n "${MOCK_PS_COUNTER_FILE:-}" ]; then
    count=0
    [ -f "$MOCK_PS_COUNTER_FILE" ] && count=$(cat "$MOCK_PS_COUNTER_FILE")
    count=$(( count + 1 ))
    echo "$count" > "$MOCK_PS_COUNTER_FILE"
    [ "$count" -ge "$MOCK_PS_LOADED_AFTER" ] && loaded=1
  fi

  if [ "$loaded" = "1" ]; then
    echo "{\"models\":[{\"name\":\"$model_name\",\"size\":4000000000}]}"
  else
    echo '{"models":[]}'
  fi
  exit "${MOCK_CURL_OLLAMA_EXIT:-${MOCK_CURL_EXIT:-0}}"

# larql /v1/models health check
elif echo "$args" | grep -q "v1/models" && ! echo "$args" | grep -q "openrouter"; then
  _log "v1/models"
  # B6: seam to return a specific model id (defaults to "smollm2-360m" if unset)
  _model_id="${MOCK_LARQL_MODEL_ID:-smollm2-360m}"
  # Port-specific override: succeed only for MOCK_LARQL_PORT_RUNNING port (B1 singleton test).
  # Any v1/models request to a different port fails.
  if [ -n "${MOCK_LARQL_PORT_RUNNING:-}" ]; then
    if echo "$args" | grep -q ":${MOCK_LARQL_PORT_RUNNING}/"; then
      echo "{\"data\":[{\"id\":\"${_model_id}\"}]}"
      exit 0
    else
      exit 1
    fi
  fi
  # Stateful: become running after N health-check calls (mirrors MOCK_PS_LOADED_AFTER)
  if [ -n "${MOCK_LARQL_RUNNING_AFTER:-}" ] && [ -n "${MOCK_LARQL_COUNTER_FILE:-}" ]; then
    count=0
    [ -f "$MOCK_LARQL_COUNTER_FILE" ] && count=$(cat "$MOCK_LARQL_COUNTER_FILE")
    count=$(( count + 1 ))
    echo "$count" > "$MOCK_LARQL_COUNTER_FILE"
    if [ "$count" -ge "$MOCK_LARQL_RUNNING_AFTER" ]; then
      echo "{\"data\":[{\"id\":\"${_model_id}\"}]}"
      exit 0
    else
      exit 1
    fi
  fi
  # MOCK_LARQL_RUNNING=0 forces health check failure (simulates larql not yet started)
  if [ "${MOCK_LARQL_RUNNING:-}" = "0" ]; then
    exit 1
  fi
  if [ "${MOCK_CURL_LARQL_EXIT:-${MOCK_CURL_EXIT:-0}}" = "0" ]; then
    echo "{\"data\":[{\"id\":\"${_model_id}\"}]}"
    exit 0
  else
    exit 1
  fi

else
  _log "ollama-other"
  exit "${MOCK_CURL_OLLAMA_EXIT:-${MOCK_CURL_EXIT:-0}}"
fi

#!/usr/bin/env bash
set -euo pipefail
# SPDX-License-Identifier: AGPL-3.0-or-later
# Mock larql binary — records invocations; "serve" exits immediately.
if [ -n "${MOCK_CALL_LOG:-}" ]; then
  echo "larql $*" >> "$MOCK_CALL_LOG"
fi
# For "serve": return immediately, OR stay alive for PID-cleanup tests.
# Set MOCK_LARQL_SERVE_STAY_ALIVE=1 and MOCK_LARQL_SERVE_PID_FILE to test cleanup.
if [ "${1:-}" = "serve" ]; then
  if [ -n "${MOCK_LARQL_SERVE_PID_FILE:-}" ]; then
    # Simulate larql behavior: fork a long-running child (like larql-server), then exit.
    # Write child PID so the test can verify it was killed.
    sleep 9999 &
    echo $! > "$MOCK_LARQL_SERVE_PID_FILE"
  fi
  exit 0  # exits immediately, like real larql does after spawning larql-server
fi
exit "${MOCK_LARQL_EXIT:-0}"
